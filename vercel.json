{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/a-propos", "destination": "/entreprise", "permanent": true },
    { "source": "/notre-histoire", "destination": "/entreprise", "permanent": true }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/espace-client", "destination": "/index.html" },
    { "source": "/espace-client/:path*", "destination": "/index.html" },
    { "source": "/realisations/:slug", "destination": "/index.html" },
    { "source": "/blog/:slug", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
